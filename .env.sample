# Configure Github OAuth
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_VALID_EMAILS=

# Use a Docker PAT, Docker OAT, or Github PAT IF NECESSARY (for private repos)
# PULL_SECRET_USER=
# PULL_SECRET_TOKEN=

# Development profile: path to local ICC/machinist repository
# ICC_REPO=/work/workspaces/workspace-platformatic/icc3
# MACHINIST_REPO=/work/workspaces/workspace-platformatic/machinist

# Skew-protection profile: path to workflow monorepo root (NOT packages/workflow)
# WORKFLOW_REPO=/work/workspaces/workspace-platformatic/platformatic-world

# Regina profile: path to ebpf-sandbox monorepo root (NOT packages/server)
# EBPF_SANDBOX_REPO=/work/workspaces/workspace-platformatic/ebpf-sandbox

# Override the Platformatic helm chart with a local path (for chart development)
# PLT_HELM_CHART_PATH=/work/workspaces/workspace-platformatic/helm/chart
